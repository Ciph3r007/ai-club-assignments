# QueryGraph Agent - environment configuration template
# Copy this file to .env and fill in your values.
# The .env file is gitignored; never commit secrets.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string for the Northwind database.
# docker compose up starts postgres on localhost:5432 with the defaults below.
DATABASE_URL=postgresql+psycopg://querygraphuser:querygraphpass@localhost:5432/northwind

# Maximum number of rows returned per db_query call. Range: 1..1000. Default: 100.
DB_MAX_ROWS=100

# Query execution timeout in seconds. Range: 1..120. Default: 10.
DB_QUERY_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Ollama / LLM
# ---------------------------------------------------------------------------
# Base URL for the local Ollama server.
OLLAMA_BASE_URL=http://localhost:11434

# Primary model name. Must support tool calling.
OLLAMA_MODEL=qwen2.5-coder:14b

# Comma-separated ordered fallback models to try if the primary fails.
OLLAMA_FALLBACK_MODELS=qwen3:8b,llama3.2

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL. Default: INFO.
LOG_LEVEL=INFO
